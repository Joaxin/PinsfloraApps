{
    "plugins": ["splitter","expandable-chapters","-sharing", "sharing-plus","popup","-lunr","-search", "search-plus", "ga", "hide-element","back-to-top-button","code","advanced-emoji","tbfed-pagefooter","page-treeview"],
    "pluginsConfig": {
            "sharing": {
             "douban": true,
             "facebook": true,
             "pocket": false,
             "twitter": true,
             "weibo": true,
          "all": [
               "douban", "facebook",  "instapaper", "linkedin","twitter", "weibo", 
               "messenger","qq", "qzone","viber","whatsapp"
           ]
       },
       "ga": {
            "token": "UA-153171056-1"
        },
         "hide-element": {
            "elements": [".gitbook-link",".custom-link"]
        },
        "tbfed-pagefooter": {
            "copyright":"Copyright &copy pinsflora.com 2019",
            "modify_label": "修订时间：",
            "modify_format": "YYYY-MM-DD HH:mm:ss"
        },
        "page-treeview": {
            "copyright": "Copyright &#169; aleen42",
            "minHeaderCount": "2",
            "minHeaderDeep": "2"
        }
    }
}